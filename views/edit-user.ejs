<div class="modal-overlay">
  <div class="modal">

    <h2>Edit User</h2>

    <form method="POST" action="/user/<%= user.id %>/edit">

      <label>Name</label>
      <input type="text" name="name" value="<%= user.name %>" required>

      <label>Description</label>
      <textarea name="description" required><%= user.description %></textarea>

      <label>Daily goal steps (only integer)</label>
      <input type="number" name="dailyGoalSteps" value="<%= user.dailyGoalSteps %>" required>

      <label>Active</label>
      <select name="isActive">
        <option value="true" <%= user.isActive ? "selected" : "" %>>Active</option>
        <option value="false" <%= !user.isActive ? "selected" : "" %>>Inactive</option>
      </select>

      <label>Plan</label>
      <select name="plan">
        <option value="Free" <%= user.plan === "Free" ? "selected" : "" %>>Free</option>
        <option value="Plus" <%= user.plan === "Plus" ? "selected" : "" %>>Plus</option>
        <option value="Pro" <%= user.plan === "Pro" ? "selected" : "" %>>Pro</option>
      </select>

      <div class="modal-actions">
        <a href="/user/<%= user.id %>" class="cancel-btn">Cancel</a>
        <button type="submit" class="save-btn">Save</button>
      </div>

    </form>
  </div>
</div>