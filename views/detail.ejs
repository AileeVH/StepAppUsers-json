<!DOCTYPE html>
<html>
<head>
    <title><%= user.name %></title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="layout">
        <%- include("templates/nav") %>

        <main class="detail-page">

            <% if (typeof showModal !== "undefined" && showModal) { %>
                <%- include("edit-user", { user }) %>
            <% } %>

            <h1 class="detail-title"><%= user.name %></h1>

            <a class="view-link" href="/user/<%= user.id %>/edit">Edit user</a>

            <div class="detail-grid">
                <section class="profile-card">
                    <img class="detail-user-img" src="/images/users/<%= user.name %>.png" />

                    <div class="status-pill <%= user.isActive ? 'pill-active' : 'pill-inactive' %>">
                        <span class="status-dot <%= user.isActive ? 'active-true' : 'active-false' %>"></span>
                        <%= user.isActive ? "Active" : "Inactive" %>
                    </div>

                    <div class="detail-info-list">
                        <div class="detail-info-row">
                            <span class="detail-icon">📅</span>
                            <div>
                                <p>Birthdate</p>
                                <strong><%= user.birthDate %></strong>
                            </div>
                        </div>

                        <div class="detail-info-row">
                            <span class="detail-icon">🎯</span>
                            <div>
                                <p>Daily Goal Steps</p>
                                <strong><%= user.dailyGoalSteps %> steps</strong>
                            </div>
                        </div>

                        <div class="detail-info-row">
                            <span class="detail-icon">👑</span>
                            <div>
                                <p>Plan</p>
                                <strong><%= user.plan %></strong>
                            </div>
                        </div>

                        <div class="detail-info-row">
                            <span class="detail-icon">🏃</span>
                            <div>
                                <p>Favorite Activities</p>
                                <strong><%= user.favoriteActivities.join(", ") %></strong>
                            </div>
                        </div>

                        <div class="detail-info-row">
                            <span class="detail-icon">📄</span>
                            <div>
                                <p>Description</p>
                                <strong><%= user.description %></strong>
                            </div>
                        </div>
                    </div>
                </section>

                <a href="/device/<%= user.device.id %>/<%= user.id %>" class="device-link">
                    <section class="device-card">
                        <h2>Device</h2>

                        <div class="device-content">
                            <img class="detail-device-img" src="/images/devices/<%= user.device.brand %> <%= user.device.model %>.png" />
                            <h3><%= user.device.brand %> <%= user.device.model %></h3>
                        </div>
                    </section>
                </a>
            </div>

        </main>
    </div>
</body>
</html>